# Copy to ".env" next to ServerCRON.py (same folder). Keys already set in Windows / terminal are NOT overwritten.

# Use UTF-8 without BOM. Lines starting with # are ignored.

# --- Boot (opcional) ---
# Não executar "pip install -r requirements.txt" no arranque (útil se o pip falhar ou o ambiente já estiver pronto).
# SERVERCRON_SKIP_REQUIREMENTS_PIP=1



# --- registro_automacoes.xlsx (folhas USERS + AUTOMACOES) ---

# Absolute path to the workbook (overrides directory + default name):

# SERVERCRON_REGISTRO_XLSX=C:\caminho\absoluto\registro_automacoes.xlsx

# Or directory containing registro_automacoes.xlsx (default filename fixed):

# SERVERCRON_REGISTRO_DIR=C:\caminho\pasta_com_planilha



# Cache tuning for USERS sheet reload (legacy env names kept for compatibility):

# SERVERCRON_BQ_PERMS_FRESH_TTL_SEC=120

# SERVERCRON_BQ_PERMS_STALE_MAX_SEC=86400



# --- Paths ---

# Absolute path: automation tree + config (default: %USERPROFILE%\Documents\ServerCRON)

# SERVERCRON_DATA_ROOT=C:\caminho\absoluto\ServerCRON



# Panel templates/static (default: folder of ServerCRON.py). Set if HTML/CSS/JS live elsewhere.

# SERVERCRON_PANEL_DIR=C:\apps\ServerCRON



# --- Network / ports ---

# Single port (default): Uploaders on / and Cron on /cron/

# SERVERCRON_DUO_PORTS=0

# SERVERCRON_UNIFIED_PORT=5001



# Two ports: Uploaders + Cron as separate origins (also set SERVERCRON_DUO_PORTS=1 in practice via code paths)

# SERVERCRON_DUO_PORTS=1

# SERVERCRON_UP_PORT=5001

# SERVERCRON_CRON_PORT=5002



# Prefix where Cron app is mounted in unified mode (usually leave default when using duo_ports=0)

# SERVERCRON_CRON_URL_PREFIX=/cron



# --- Login e-mail (Uploaders) ---

# Suffix matched against USERS "users" column (e.g. @banco.com.br)

# SERVERCRON_EMAIL_DOMAIN=@yourbank.com.br



# --- Outlook (optional: monitor mailbox display name; empty = profile default Inbox) ---

# SERVERCRON_OUTLOOK_MONITOR_MAILBOX=Monitoracao Python



# --- UX ---

# SERVERCRON_OPEN_BROWSER=0

